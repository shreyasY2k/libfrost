# =============================================================================
# LibreChat Environment Configuration for Enterprise LLM Stack
# =============================================================================

# Server
HOST=0.0.0.0
PORT=3080
DOMAIN_SERVER=http://localhost:3080
DOMAIN_CLIENT=http://localhost:3080

# MongoDB
MONGO_URI=mongodb://mongodb:27017/librechat

# Meilisearch
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=meili_master_key

# =============================================================================
# OpenID Connect (Keycloak)
# =============================================================================
OPENID_ISSUER=http://keycloak:8180/realms/enterprise
OPENID_CLIENT_ID=librechat
OPENID_CLIENT_SECRET=librechat-client-secret
OPENID_CALLBACK_URL=/oauth/openid/callback
OPENID_SCOPE=openid profile email organization
OPENID_BUTTON_LABEL=Login with Enterprise SSO
OPENID_IMAGE_URL=

# Disable local auth when using enterprise SSO
ALLOW_EMAIL_LOGIN=false
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false

# =============================================================================
# Session / JWT
# =============================================================================
CREDS_KEY=replace-with-random-32-char-key!!
CREDS_IV=replace-with-16char!
JWT_SECRET=replace-with-random-jwt-secret-key
JWT_REFRESH_SECRET=replace-with-random-refresh-secret

# =============================================================================
# Misc
# =============================================================================
DEBUG_LOGGING=true
SEARCH=true
